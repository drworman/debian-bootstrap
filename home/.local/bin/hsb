#!/usr/bin/env python3
# hsb — Host-aware Sync Batch
#
# Usage:
#   hsb
#
# Detects the current host's FQDN and runs the matching Unison profile.
# If the host is the configured laptop AND it is currently NOT on the
# home subnet, the REMOTE_PROFILE is used instead of the LAN profile —
# this lets the laptop sync over the public network when away from home.
#
# Profiles must already exist in ~/.unison/. Profile filename convention:
#   <fqdn>.prf            — used on LAN
#   <hostname>_remote.prf — used when off-LAN
#
# Dependencies: python3 (>=3.8), unison, hostname
#
# ─── User-editable variables ────────────────────────────────────────────────
# Prefix that identifies your home network's IPv4 subnet.
HOME_SUBNET     = "192.168."

# FQDN of the laptop that should switch to a remote profile when off-LAN.
LAPTOP_HOSTNAME = "host.domain.net"

# Filename of the off-LAN profile (relative to ~/.unison/).
REMOTE_PROFILE  = "hostname_remote.prf"
# ─── Do not edit below this line ────────────────────────────────────────────

import subprocess
import socket

command = ["hostname", "-f"]


def get_local_ip():
    try:
        s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
        s.connect(("8.8.8.8", 80))
        return s.getsockname()[0]
    except Exception:
        return ""
    finally:
        s.close()

result = subprocess.run(command, capture_output=True, text=True, check=True)
current_host = result.stdout.strip('\n')
unisonProfile = current_host + ".prf"

if current_host == LAPTOP_HOSTNAME:
    local_ip = get_local_ip()
    if not local_ip.startswith(HOME_SUBNET):
        unisonProfile = REMOTE_PROFILE

try:
    subprocess.run(['unison', unisonProfile])
except subprocess.CalledProcessError:
    pass
